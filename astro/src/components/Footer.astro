---
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const currentYear = new Date().getFullYear();
const logoUrl = `${baseUrl}/images/logo-blanc.svg`;
---

<footer class="bg-slate-900 text-slate-400 border-t border-slate-800 font-sans">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">

        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-12 mb-12">
            <!-- Colonne 1 : Brand & Pitch -->
            <div class="md:col-span-2 space-y-4">
                <a href={`${baseUrl}/`} class="flex items-center gap-3 group transition-transform duration-200 select-none">
                    <img
                            src={logoUrl}
                            alt="Code With Us Logo"
                            class="w-10 h-10 object-contain shrink-0"
                    />
                    <!-- Nom de la marque sur une seule ligne et en plus gros -->
                    <span class="font-black text-lg text-white tracking-wide leading-none uppercase">
                        Code with us
                    </span>
                </a>
                <p class="text-sm text-slate-400 max-w-sm leading-relaxed">
                    Par les devs, pour les devs. Entreprise de Services Numériques spécialisée dans la conception de solutions durables et le développement de logiciels d'excellence.
                </p>
            </div>

            <!-- Colonne 2 : Navigation Raccourcis -->
            <div class="space-y-4">
                <h4 class="text-white text-xs font-bold uppercase tracking-wider text-slate-200">
                    Navigation
                </h4>
                <ul class="space-y-2.5 text-sm">
                    <li>
                        <a href={`${baseUrl}/#approche`} class="hover:text-esn-blue transition-colors">Notre approche</a>
                    </li>
                    <li>
                        <a href={`${baseUrl}/#expertises`} class="hover:text-esn-blue transition-colors">Expertises</a>
                    </li>
                    <li>
                        <a href={`${baseUrl}/#realisations`} class="hover:text-esn-blue transition-colors">Réalisations</a>
                    </li>
                    <li>
                        <a href={`${baseUrl}/talks`} class="hover:text-esn-blue transition-colors">Talks</a>
                    </li>
                    <li>
                        <a href={`${baseUrl}/equipe`} class="hover:text-esn-blue transition-colors">L'équipe</a>
                    </li>
                </ul>
            </div>

            <!-- Colonne 3 : Contact & Siege -->
            <div class="space-y-4">
                <h4 class="text-white text-xs font-bold uppercase tracking-wider text-slate-200">
                    Contact & Siège
                </h4>
                <ul class="space-y-3 text-sm">
                    <!-- Localisation -->
                    <li class="flex items-start gap-3 text-slate-300">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-slate-400 shrink-0 mt-0.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                        </svg>
                        <span>4 rue des Genêts,<br/>35650 LE RHEU</span>
                    </li>

                    <!-- Mail -->
                    <li>
                        <a href="mailto:contact@codewithus.fr" class="flex items-center gap-3 text-slate-300 hover:text-esn-blue transition-colors group/mail">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-slate-400 group-hover/mail:text-esn-blue transition-colors shrink-0">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0l-7.5-4.615a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                            </svg>
                            <span class="underline decoration-transparent group-hover/mail:decoration-esn-blue transition-all">contact@codewithus.fr</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Ligne du bas : Copyright & Mentions Légales -->
        <div class="pt-8 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs">
            <p>
                Copyright © {currentYear} Code with us. Tous droits réservés.
            </p>
            <div class="flex gap-6">
                <a href={`${baseUrl}/mentions-legales`} class="hover:text-white transition-colors underline decoration-slate-700 hover:decoration-white">
                    Mentions légales
                </a>
            </div>
        </div>

    </div>
</footer>
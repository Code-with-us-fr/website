---
import clients from '../data/clients.json';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="bg-white py-16 sm:py-24 border-t border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- En-tête de la section -->
        <div class="text-center max-w-3xl mx-auto mb-14">
            <h2 class="text-xs font-bold uppercase tracking-wider text-esn-blue mb-3">
                RÉFÉRENCES
            </h2>
            <p class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">
                Ils nous font confiance au quotidien
            </p>
        </div>

        <!-- Grille des logos avec noms -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-y-12 gap-x-8 items-start justify-items-center">
            {clients.map((client) => (
                    <div class="w-full max-w-[140px] flex flex-col items-center text-center group gap-3">

                        <!-- Conteneur du Logo -->
                        <div class="h-16 w-full flex items-center justify-center">
                            <img
                                    src={`${baseUrl}/${client.logo}`}
                                    alt={`Logo ${client.name}`}
                                    title={client.name}
                                    loading="lazy"
                                    class="max-w-full max-h-full object-contain filter grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300 ease-in-out transform group-hover:scale-105"
                            />
                        </div>

                        <!-- Nom du client en dessous -->
                        <span class="text-xs font-medium text-slate-400 group-hover:text-slate-600 transition-colors duration-300 tracking-wide">
            {client.name}
          </span>

                    </div>
            ))}
        </div>

    </div>
</section>
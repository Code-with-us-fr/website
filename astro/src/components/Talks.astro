---
import { Image } from 'astro:assets';
import talks from '../data/talks.json';

// Récupère la base configurée pour GitHub Pages pour gérer correctement le lien vers la page dédiée
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

// On ne sélectionne que les 3 premiers talks pour la page d'accueil
const recentTalks = talks.slice(0, 3);

// Fonction pour extraire l'ID YouTube afin de générer l'URL de la miniature
function getYouTubeId(url) {
    if (!url) return null;
    const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?\s*v=|\&v=)([^#\&\?]*).*/;
    const match = url.match(regExp);
    return (match && match[2].length === 11) ? match[2] : null;
}
---

<section id="talks" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 scroll-mt-24">
    <div class="flex justify-between items-end mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Nos derniers talks</h2>
        <a
                href={`${baseUrl}/talks`}
                class="flex items-center justify-center gap-2 text-esn-blue-dark text-sm font-semibold hover:text-esn-blue transition py-3 group"
        >
            Voir tous les talks <span class="group-hover:translate-x-1 transition-transform">→</span>
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentTalks.map((talk) => {
            const videoId = getYouTubeId(talk.youtubeUrl);
            // On utilise la miniature YouTube si l'URL existe, sinon on garde l'ancienne propriété talk.image en secours
            const thumbnailUrl = videoId
                ? `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`
                : talk.image;

            return (
                    <a
                            href={talk.youtubeUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="bg-white rounded-xl overflow-hidden border border-slate-100 shadow-sm hover:shadow-md transition group block"
                    >
                        <div class="h-48 overflow-hidden relative">
                            <Image
                                    src={thumbnailUrl}
                                    alt={talk.title}
                                    width={480}
                                    height={270}
                                    class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
                            />
                            <div class="absolute bottom-3 left-3 bg-black/60 text-white text-xs px-2 py-1 rounded backdrop-blur-sm font-medium">
                                ▶ Regarder sur YouTube
                            </div>
                        </div>
                        <div class="p-5 space-y-2">
                            <h3 class="font-bold text-slate-900 group-hover:text-esn-blue transition duration-150 line-clamp-1">
                                {talk.title}
                            </h3>
                            <p class="text-xs text-slate-500 font-medium">{talk.event}</p>
                        </div>
                    </a>
            );
        })}
    </div>
</section>